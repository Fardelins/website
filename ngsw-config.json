{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/main-*.js", "/styles-*.css", "/polyfills-*.js"]
      }
    },
    {
      "name": "visual-assets-and-lazy-chunks",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/home/**", "/contact/**", "/blogs/**", "/features/**", "/chunk-*.js"]
      },
      "cacheQueryOptions": { "ignoreSearch": true }
    }
  ],
  "dataGroups": [
    {
      "name": "published-blog-content",
      "urls": ["https://fardelins.com/wp-json/wp/v2/posts**", "https://fardelins.com/wp-json/wp/v2/categories**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 60,
        "maxAge": "1h",
        "timeout": "5s"
      }
    }
  ],
  "navigationUrls": ["/**", "!/**/*.*", "!/wp-admin/**", "!/wp-json/**", "!/contact-form-config"]
}
