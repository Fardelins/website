{
  "name": "fardelins-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "prebuild": "node scripts/generate-sitemap.mjs",
    "build": "ng build",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:fonts": "node scripts/selfhost-fonts.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --no-watch",
    "lint": "prettier --check \"src/**/*.{ts,html,css}\" \"scripts/**/*.mjs\"",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" \"scripts/**/*.mjs\"",
    "serve:prod": "serve -s dist/fardelins-app/browser",
    "serve:ssr:fardelins-app": "node dist/fardelins-app/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.22.3 <23"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "22.0.5",
    "@angular/ssr": "^22.0.5",
    "compression": "^1.8.0",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "shaders": "^2.5.135",
    "tslib": "^2.3.0",
    "web-haptics": "0.0.6"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "serve": "^14.2.4",
    "sharp": "^0.35.3",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
